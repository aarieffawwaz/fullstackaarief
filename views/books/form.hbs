<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>{{#if book}}Edit Book{{else}}Tambah Book{{/if}}</title>
</head>
<body>
  <nav>
    <a href="/authors">Authors</a> |
    <a href="/books">Books</a> |
    <form action="/logout" method="POST" style="display:inline">
      <button type="submit">Logout</button>
    </form>
  </nav>

  <h1>{{#if book}}Edit Book{{else}}Tambah Book{{/if}}</h1>

  <form action="{{action}}" method="POST">
    <div>
      <label>Judul:</label>
      <input type="text" name="title" value="{{book.title}}" required>
    </div>
    <div>
      <label>Tahun:</label>
      <input type="number" name="year" value="{{book.year}}" required>
    </div>
    <div>
      <label>Author:</label>
      <select name="authorId" required>
        <option value="">-- Pilih Author --</option>
        {{#each authors}}
        <option value="{{this.id}}" {{#if (eq this.id ../book.authorId)}}selected{{/if}}>{{this.name}}</option>
        {{/each}}
      </select>
    </div>
    <button type="submit">Simpan</button>
  </form>

  <p><a href="/books">Kembali</a></p>
</body>
</html>

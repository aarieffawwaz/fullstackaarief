<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Detail Author</title>
</head>
<body>
  <nav>
    <a href="/authors">Authors</a> |
    <a href="/books">Books</a> |
    <form action="/logout" method="POST" style="display:inline">
      <button type="submit">Logout</button>
    </form>
  </nav>

  <h1>Detail Author</h1>

  <p><strong>ID:</strong> {{author.id}}</p>
  <p><strong>Nama:</strong> {{author.name}}</p>
  <p><strong>Bio:</strong> {{author.bio}}</p>

  <h2>Buku-buku</h2>
  <ul>
    {{#each author.books}}
    <li><a href="/books/{{this.id}}">{{this.title}}</a> ({{this.year}})</li>
    {{else}}
    <li>Belum ada buku.</li>
    {{/each}}
  </ul>

  <p>
    <a href="/authors/{{author.id}}/edit">Edit</a> |
    <a href="/authors">Kembali</a>
  </p>
</body>
</html>
